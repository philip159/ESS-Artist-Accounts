PAYPAL_SANDBOX = "true"
AR_TEST_TOKEN = "ae8281b1dc262196b6fa6525d594704e752ea47388c94ab8"
NODE_OPTIONS = "--max-old-space-size=2048"
POSTPONE_INSTAGRAM_USERNAME = "eastsidestudio_london"
